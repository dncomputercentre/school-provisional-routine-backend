generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["school"]
}

model SchoolHeadMaster {
  id                 String   @id @default(uuid())
  email              String   @unique
  password           String
  mustChangePassword Boolean  @default(true)
  createdAt          DateTime @default(now())

  @@schema("school")
}

model SchoolTeacher {
  id               String   @id @default(uuid())
  name             String
  mobile           String
  mainSubject      String
  optionalSubjects String[]
  createdAt        DateTime @default(now())

  routines ClassRoutine[]
  absents  SchoolTeacherAbsent[]

  @@schema("school")
}

model SchoolTeacherAbsent {
  id        String   @id @default(uuid())
  teacherId String
  date      DateTime

  teacher SchoolTeacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@schema("school")
}

model ClassRoutine {
  id        String   @id @default(uuid())
  className String
  section   String
  period    String
  time      String
  subject   String
  teacherId String
  createdAt DateTime @default(now())
  day       String

  teacher SchoolTeacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@schema("school")
}

model SchoolSubject {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  @@schema("school")
}